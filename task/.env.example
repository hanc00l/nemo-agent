# LLM 1 API 配置
LLM-1-ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
LLM-1-ANTHROPIC_AUTH_TOKEN=
LLM-1-ANTHROPIC_MODEL="GLM-5"

# LLM 2 API 配置 (可选)
LLM-2-ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
LLM-2-ANTHROPIC_AUTH_TOKEN=
LLM-2-ANTHROPIC_MODEL=Doubao-Seed-2.0-Code

# LLM 3 API 配置 (可选)
LLM-3-ANTHROPIC_BASE_URL=
LLM-3-ANTHROPIC_AUTH_TOKEN=
LLM-3-ANTHROPIC_MODEL=

# ====================
# 竞赛平台配置
# ====================
# 平台 API 地址 (不带 /api 后缀)
COMPETITION_API_URL=http://host.docker.internal:8888
# Agent Token (在比赛管理后台获取)
AGENT_TOKEN=your_agent_token_here
# 兼容旧配置名 (已废弃，优先使用 AGENT_TOKEN)
# COMPETITION_API_TOKEN=your_token_here

# ====================
# 调度器配置 (Scheduler)
# ====================

# 平台获取间隔 (秒)
FETCH_INTERVAL=60

# 同时使用的LLM数量 (1-3)
MAX_LLM=1

# 最大并行挑战数量 (平台限制每队同时运行 3 个赛题实例)
MAX_PARALLEL=3

# 单个挑战超时时间 (秒)
TIMEOUT_SECONDS=2400

# Docker 镜像
DOCKER_IMAGE=nemo-agent/sandbox:1.0

# VNC 基础端口
VNC_BASE_PORT=55900

# 是否禁用 VNC (true=禁用VNC, 不分配VNC端口)
NO_VISION=true

# 状态文件路径（相对路径，基于 task 目录）
STATE_FILE=data/subjects.json

# 日志文件路径（相对路径，基于 task 目录）
LOG_FILE=data/scheduler.log

# 笔记存储路径（宿主机路径，容器会挂载到此目录）
NOTE_PATH=/opt/notes

# Jupyter notebook 存储路径（宿主机路径，容器会挂载到此目录）
NOTEBOOK_PATH=/opt/scripts

# ====================
# 反连工具配置
# ====================

# 网络模式 (固定 bridge，端口映射隔离)
NETWORK_MODE=bridge

# 反弹 IP (目标回连到本机的可达 IP，必须配置)
REVERSE_IP=192.168.52.101

# 端口由调度器自动分配，每个容器 10 个端口，从 20000 起:
#   PORT_NC            NC 反弹 shell（主）
#   PORT_NC2           NC 反弹 shell（备）
#   PORT_JNDI_LDAP     JNDI LDAP
#   PORT_JNDI_HTTP     JNDI HTTP
#   PORT_SOCKS5        SOCKS5 代理
#   PORT_FRP           frp 服务端
#   PORT_FRP_DASHBOARD frp Dashboard
#   PORT_MSF           Metasploit
#   PORT_CHISEL        chisel 服务端
#   PORT_STOWAWAY      Stowaway 管理端

# 工作目录（用于终端会话、反连工具起始目录、JNDIExploit.jar 所在目录）
WORKSPACE_PATH=/opt/workspace

# ====================
# Web UI 配置
# ====================

# Web UI 登录
WEB_UI_USERNAME=nemo
WEB_UI_PASSWORD=nemo
